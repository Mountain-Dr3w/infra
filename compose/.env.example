# Copy to .env and fill in values
# Generated by bootstrap/04-setup-secrets.sh on the VPS

POSTGRES_USER=enforcer
POSTGRES_PASSWORD=CHANGE_ME

DOMAIN=example.dev

DATABASE_URL=postgresql://enforcer:CHANGE_ME@postgres:5432/enforcer_dev
NODE_ENV=production
PORT=3001

# Velveteen's per-project Postgres: admin credentials for the shared
# user-postgres container. The worker uses these to CREATE USER/DATABASE for
# each deployed project; the resulting per-project DATABASE_URL points at the
# same host (`user-postgres:5432`) on velveteen-network.
USER_POSTGRES_ADMIN_USER=velveteen_admin
USER_POSTGRES_ADMIN_PASSWORD=CHANGE_ME
USER_POSTGRES_ADMIN_URL=postgresql://velveteen_admin:CHANGE_ME@user-postgres:5432/postgres
